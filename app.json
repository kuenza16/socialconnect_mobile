{
  "expo": {
    "name": "socialconnect-mobile",
    "slug": "socialconnect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ChatGPT Image May 19, 2026, 02_48_46 PM.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F5F2FF"
    },
    "scheme": "socialconnectmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SConnect needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "SConnect needs microphone access for audio and video calls."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/ChatGPT Image May 19, 2026, 02_48_46 PM.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kuenzang.socialconnectmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#F5F2FF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eee620cd-d91a-4695-8bee-25ce93bd97b1"
      }
    }
  }
}
