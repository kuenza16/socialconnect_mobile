{
  "expo": {
    "name": "socialconnect-mobile",
    "slug": "socialconnect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "socialconnectmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SConnect needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "SConnect needs microphone access for audio and video calls."
      }
    },

    "android": {
      "usesCleartextTraffic": true,
      "permissions": ["CAMERA", "RECORD_AUDIO", "INTERNET"],

      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,

      "package": "com.kuenzang.socialconnectmobile"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",

          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
