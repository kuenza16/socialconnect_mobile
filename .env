# API base URL including /api suffix
# Android emulator -> host machine = 10.0.2.2
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5000/api

# WebSocket base URL (no /api suffix)
EXPO_PUBLIC_WS_URL=http://10.0.2.2:5000

# Optional: override android host without changing URLs above
EXPO_PUBLIC_ANDROID_HOST=10.0.2.2

# Request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT_MS=15000
