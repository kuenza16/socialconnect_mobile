{
  "cli": {
    "version": ">= 18.13.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_BUILD_CACHE": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_BUILD_CACHE": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
